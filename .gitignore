# =============================================================================
# LumenGPS — Fabric Mod .gitignore
# =============================================================================

# ── Gradle build outputs ─────────────────────────────────────────────────────
build/
.gradle/

# gradle/wrapper/gradle-wrapper.jar

# ── IntelliJ IDEA ────────────────────────────────────────────────────────────
.idea/
*.iml
*.iws
*.ipr
out/

# ── VS Code ───────────────────────────────────────────────────────────────────
# Manter .vscode/tasks.json e .vscode/settings.json no versionamento.
# Ignorar apenas configs pessoais e caches locais:
.vscode/.browse.vc.db*
.vscode/ipch/
.vscode/*.code-workspace

# ── Eclipse ───────────────────────────────────────────────────────────────────
.classpath
.project
.settings/
bin/

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
__MACOSX/

# ── Windows ───────────────────────────────────────────────────────────────────
Thumbs.db
desktop.ini

# ── Java ──────────────────────────────────────────────────────────────────────
*.class
*.jar
!gradle/wrapper/gradle-wrapper.jar

# ── Logs e temporários ────────────────────────────────────────────────────────
*.log
*.tmp
*.bak
